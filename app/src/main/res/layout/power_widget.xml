<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Farm label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_label"
        android:textColor="#80FFFFFF"
        android:textSize="10sp"
        android:layout_marginBottom="8dp" />

    <!-- Circular progress ring with centred percentage -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center">

        <!-- Ring bitmap drawn programmatically -->
        <ImageView
            android:id="@+id/iv_widget_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY" />

        <!-- Percentage overlaid at the centre -->
        <TextView
            android:id="@+id/tv_widget_percent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- MW value -->
    <TextView
        android:id="@+id/tv_widget_mw"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="— MW"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <!-- Status + source row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="#40FFFFFF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_widget_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#60FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>