<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── BMU IDs section ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_bmu_section"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_bmu_description"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:boxBackgroundColor="@color/card_bg"
            app:boxStrokeColor="@color/accent_cyan"
            app:hintTextColor="@color/accent_cyan"
            android:hint="@string/settings_bmu_hint"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_bmu_ids"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Test BMU suggestion ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_test_suggestion_label"
            android:textColor="#60FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_test_bmu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HEYM11"
            android:textColor="@color/accent_cyan"
            android:textSize="13sp"
            app:chipBackgroundColor="#1500D4FF"
            app:chipStrokeColor="@color/accent_cyan"
            app:chipStrokeWidth="1dp"
            app:chipIconVisible="false"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <!-- ── Buttons row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/settings_btn_reset"
                app:strokeColor="@color/accent_amber"
                android:textColor="@color/accent_amber" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_btn_save"
                android:backgroundTint="@color/accent_cyan"
                android:textColor="@color/bg_dark" />

        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- ── API source section ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_api_section"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_api_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb_api_legacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_api_legacy_label"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:buttonTint="@color/accent_cyan"
                android:paddingStart="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_api_legacy_desc"
                android:textColor="#60FFFFFF"
                android:textSize="12sp"
                android:paddingStart="40dp"
                android:layout_marginBottom="12dp" />

            <RadioButton
                android:id="@+id/rb_api_sofia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_api_sofia_label"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:buttonTint="@color/accent_cyan"
                android:paddingStart="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_sofia_api_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_api_sofia_desc_loading"
                android:textColor="#60FFFFFF"
                android:textSize="12sp"
                android:paddingStart="40dp" />

        </RadioGroup>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- ── Test mode info ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_test_mode_title"
                    android:textColor="@color/accent_amber"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_test_mode_description"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
